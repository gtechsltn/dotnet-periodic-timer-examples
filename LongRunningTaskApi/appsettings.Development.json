{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OrderProcessing": {
    "ChannelCapacity": 100,
    "MaxDegreeOfParallelism": 5,
    "RetryCount": 3,
    "RetryBaseDelaySeconds": 1,
    "HeavyTaskDurationMs": 3000,
    "SimulatedTransientFailureRate": 0
  }
}